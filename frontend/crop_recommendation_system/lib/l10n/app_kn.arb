"question1": "ರೋಗ ಪತ್ತೆ ಹೇಗೆ ಕೆಲಸ ಮಾಡುತ್ತದೆ?",
"answer1": "AI ಚಿತ್ರ ಗುರುತಿಸುವ ತಂತ್ರಜ್ಞಾನ ಬಳಸಿ, ನೀವು ಫೋನ್ ಕ್ಯಾಮೆರಾದಿಂದ ಹಾನಿಗೊಂಡ ಎಲೆಯ ಸ್ಪಷ್ಟ ಚಿತ್ರವನ್ನು ತೆಗೆದರೆ ಸಾಕು. ಅಪ್ಲಿಕೇಶನ್ ಅದನ್ನು ಸಾವಿರಾರು ತಿಳಿದಿರುವ ರೋಗಗಳ ಚಿತ್ರಗಳೊಂದಿಗೆ ಹೋಲಿಸಿ ಸಮಸ್ಯೆಯನ್ನು ಪತ್ತೆ ಮಾಡುತ್ತದೆ. ಪತ್ತೆಯಾದ ನಂತರ, ಸಾಧ್ಯವಾದ ಕಾರಣಗಳು, ಸಲಹೆಯ ಚಿಕಿತ್ಸೆಗಳು ಮತ್ತು ಸರಳ ಭಾಷೆಯಲ್ಲಿ ಮೂಲ ತಡೆ ಕ್ರಮಗಳನ್ನು ತೋರಿಸುತ್ತದೆ.",
"question2": "ನೀರಿನ ಅವಶ್ಯಕತೆ ಹೇಗೆ ಲೆಕ್ಕ ಹಾಕಲಾಗುತ್ತದೆ?",
"answer2": "ಅಪ್ಲಿಕೇಶನ್ ಬೆಳೆ ಪ್ರಕಾರ, ಮಣ್ಣಿನ ತೇವಾಂಶ, ಸ್ಥಳೀಯ ತಾಪಮಾನ, ಗಾಳಿಯ ತೇವಾಂಶ ಮತ್ತು ಇತ್ತೀಚಿನ ಮಳೆಯ ಮಾಹಿತಿಯನ್ನು ಸೇರಿಸಿ ನೀರಿನ ಅವಶ್ಯಕತೆಯನ್ನು ಅಂದಾಜು ಮಾಡುತ್ತದೆ. ಸಾಮಾನ್ಯ ನೀರಾವರಿ ಸೂತ್ರಗಳನ್ನು ಬಳಸಿ, ಅದನ್ನು 'ಪ್ರತಿ 3 ದಿನಕ್ಕೊಮ್ಮೆ ನೀರು ಹಾಕಿ' ಎಂಬ ಸರಳ ವೇಳಾಪಟ್ಟಿಯಾಗಿ ತೋರಿಸುತ್ತದೆ, ಇದರಿಂದ ರೈತರು ಯಾವುದೇ ಲೆಕ್ಕಾಚಾರವಿಲ್ಲದೆ ನೀರಾವರಿ ಯೋಜಿಸಬಹುದು.",
"question3": "ಮಾರುಕಟ್ಟೆ ಬೆಲೆಗಳನ್ನು ಪ್ರತಿದಿನ ನವೀಕರಿಸಲಾಗುತ್ತದೆಯೇ?",
"answer3": "ಅಪ್ಲಿಕೇಶನ್‌ನಲ್ಲಿರುವ ಮಂಡಿ ಬೆಲೆಗಳನ್ನು ದಿನಕ್ಕೆ ಹಲವಾರು ಬಾರಿ ಸರ್ಕಾರ ಮತ್ತು ವಿಶ್ವಾಸಾರ್ಹ ಮಾರುಕಟ್ಟೆ ಮೂಲಗಳಿಂದ ನವೀಕರಿಸಲಾಗುತ್ತದೆ, ಇದರಿಂದ ಬೆಲೆಗಳು ಪ್ರಸ್ತುತವಾಗಿರುತ್ತವೆ. ವ್ಯಾಪಾರದ ಸಮಯದಲ್ಲಿ ಬೆಲೆಗಳು ಕೆಲವೇ ನಿಮಿಷಗಳಿಗೊಮ್ಮೆ ನವೀಕರಿಸಬಹುದು, ಇದರಿಂದ ರೈತರು ಮಾರಾಟಕ್ಕೆ ಉತ್ತಮ ಸಮಯ ಮತ್ತು ಸ್ಥಳವನ್ನು ನಿರ್ಧರಿಸಬಹುದು.",
"question4": "ಅಪ್ಲಿಕೇಶನ್ ಇಂಟರ್ನೆಟ್ ಇಲ್ಲದೆ ಕೆಲಸ ಮಾಡುತ್ತದೆಯೇ?",
"answer4": "ಸೇವ್ ಮಾಡಿರುವ ಸಲಹೆಗಳು ಮತ್ತು ಕೊನೆಯದಾಗಿ ನೋಡಿದ ಮಾಹಿತಿಯಂತಹ ಸಾಧನದಲ್ಲಿ ಈಗಾಗಲೇ ಲೋಡ್ ಆಗಿರುವ ಪ್ರಮುಖ ಮಾಹಿತಿಯನ್ನು ಇಂಟರ್ನೆಟ್ ಇಲ್ಲದಿದ್ದರೂ ಬಳಸಬಹುದು. ಹೊಸ ಹವಾಮಾನ ಮುನ್ಸೂಚನೆ ಅಥವಾ ಹೊಸ ಮಂಡಿ ಬೆಲೆಗಳಂತಹ ನೇರ ಮಾಹಿತಿಯ ಅಗತ್ಯವಿರುವ ವೈಶಿಷ್ಟ್ಯಗಳು, ಫೋನ್ ಮತ್ತೆ ಆನ್‌ಲೈನ್ ಆದಾಗ ಸ್ವಯಂಚಾಲಿತವಾಗಿ ನವೀಕರಿಸುತ್ತವೆ.",
"question5": "ರೈತರು ಸರ್ಕಾರಿ ಯೋಜನೆಗಳನ್ನು ನೋಡಬಹುದೇ?",
"answer5": "ಅಪ್ಲಿಕೇಶನ್ ಅಧಿಕೃತ ಪೋರ್ಟಲ್‌ಗಳಿಂದ ಇತ್ತೀಚಿನ ಕೃಷಿ ಯೋಜನೆಗಳು ಮತ್ತು ಸಹಾಯಧನಗಳ ಮಾಹಿತಿಯನ್ನು ತೋರಿಸುತ್ತದೆ, ವಿಶೇಷವಾಗಿ ಸಣ್ಣ ಮತ್ತು ಅಲ್ಪ ರೈತರಿಗೆ ಉಪಯುಕ್ತವಾದ ಯೋಜನೆಗಳ ಮೇಲೆ ಗಮನ ನೀಡುತ್ತದೆ. ಪ್ರತಿ ಯೋಜನೆಗೆ ಯಾರು ಅರ್ಹರು, ಮುಖ್ಯ ಪ್ರಯೋಜನಗಳು ಮತ್ತು ಅರ್ಜಿ ಸಲ್ಲಿಸುವ ಮೂಲ ಹಂತಗಳನ್ನು ರೈತರು ಸುಲಭವಾಗಿ ನೋಡಬಹುದು.",
"question6": "ನನ್ನ ಮಾಹಿತಿ ಸುರಕ್ಷಿತವಾಗಿದೆಯೇ?",
"answer6": "ಸೇವೆಯನ್ನು ನಡೆಸಲು ಅಗತ್ಯವಿರುವ ಕನಿಷ್ಠ ಮಾಹಿತಿಯನ್ನು ಮಾತ್ರ ಸಂಗ್ರಹಿಸಲಾಗುತ್ತದೆ ಮತ್ತು ಅದನ್ನು ಇತರ ಆಧುನಿಕ ಅಪ್ಲಿಕೇಶನ್‌ಗಳಂತೆ ಸಾಮಾನ್ಯ ಭದ್ರತಾ ಕ್ರಮಗಳನ್ನು ಬಳಸಿ ಸಂಗ್ರಹಿಸಲಾಗುತ್ತದೆ. ವೈಯಕ್ತಿಕ ಮಾಹಿತಿಯನ್ನು ಎಂದಿಗೂ ಮಾರಾಟ ಮಾಡಲಾಗುವುದಿಲ್ಲ ಮತ್ತು ಯಾವುದೇ ಹಂಚಿಕೆ (ಉದಾಹರಣೆಗೆ ಸರ್ಕಾರಿ ವೇದಿಕೆಗಳು ಅಥವಾ ಪಾಲುದಾರರೊಂದಿಗೆ) ಮೂಲ ಸೇವೆಗಳನ್ನು ಒದಗಿಸಲು ಮತ್ತು ಮಾಹಿತಿ ರಕ್ಷಣೆ ನಿಯಮಗಳಿಗೆ ಅನುಗುಣವಾಗಿ ಮಾತ್ರ ನಡೆಯುತ್ತದೆ.",
"question7": "ಬೆಳೆ ಉತ್ಪಾದನೆಯನ್ನು ಊಹಿಸಲು ನಾನು AI ಅನ್ನು ಹೇಗೆ ಬಳಸಬಹುದು?",
"answer7": "AI ಮಾದರಿಗಳು, ಹಿಂದಿನ ಉತ್ಪಾದನಾ ಮಾಹಿತಿ ಮತ್ತು ಸ್ಥಳೀಯ ಹವಾಮಾನ ಮಾದರಿಗಳನ್ನು ಬಳಸಿ, ಅಪ್ಲಿಕೇಶನ್ ಶಿಫಾರಸು ಮಾಡಿದ ಬೆಳೆಗೆ ಅಂದಾಜು ಉತ್ಪಾದನಾ ಮಿತಿಯನ್ನು ನೀಡುತ್ತದೆ. ಈ ಅಂದಾಜು ಯೋಜನೆಗೆ ಸಹಾಯ ಮಾಡುವ ಮಾರ್ಗದರ್ಶನ ಮಾತ್ರ, ಇದು ಖಚಿತ ಭರವಸೆ ಅಲ್ಲ, ಏಕೆಂದರೆ ನಿಜವಾದ ಉತ್ಪಾದನೆ ಹೊಲದ ನಿರ್ವಹಣೆ ಮತ್ತು ಅನಿರೀಕ್ಷಿತ ಹವಾಮಾನದಿಂದಲೂ ಪ್ರಭಾವಿತವಾಗುತ್ತದೆ.",
